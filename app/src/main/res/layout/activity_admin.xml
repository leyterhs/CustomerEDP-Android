<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include layout="@layout/toolbar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Panel"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#2196F3" />

        <Button
            android:id="@+id/btnViewClients"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Προβολή Πελατών"
            android:padding="16dp" />

        <Button
            android:id="@+id/btnAddClient"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Προσθήκη Πελάτη"
            android:padding="16dp" />
			
		<Button
			android:id="@+id/btnViewEngagements"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:text="Προβολή Engagements"
			android:padding="16dp" />
		
		<!-- <Button
			android:id="@+id/btnViewDeliveries"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:text="Προβολή Παραδόσεων"
			android:padding="16dp" /> -->
		
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="Αποσύνδεση"
            android:padding="16dp"
            android:backgroundTint="#D32F2F" />

    </LinearLayout>
</LinearLayout>