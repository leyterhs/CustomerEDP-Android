<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/engagementTitleInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Title"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/engagementDescriptionInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Description"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/engagementStatusInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Status (e.g. PENDING, IN_PROGRESS, COMPLETED)"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/engagementPriorityInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Priority (e.g. LOW, MEDIUM, HIGH)"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/engagementDueDateInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Due Date (YYYY-MM-DD)"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/engagementClientIdInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Client ID (number)"
        android:inputType="number"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/saveEngagementButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save Engagement"
        android:padding="12dp" />

</LinearLayout>